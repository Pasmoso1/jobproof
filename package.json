{
  "name": "jobproof",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:safe": "taskkill /IM node.exe /F 2>NUL || echo no-node && node -e \"try{require('fs').rmSync('.next/dev/lock',{force:true})}catch(e){}\" && next dev --webpack",
    "dev:reset": "taskkill /IM node.exe /F || echo no-node && node -e \"require('fs').rmSync('.next/dev/lock',{force:true})\" && next dev --webpack",
    "clean:dev": "node -e \"const fs=require('fs');try{fs.unlinkSync('.next/dev/lock')}catch(e){};try{fs.rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "next": "^16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
